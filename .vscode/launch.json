    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug API",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "main:app",
                "--host",
                "localhost",
                "--port",
                "8000",
                "--reload"
            ],
            "python": "${workspaceFolder}/src/backend/api/.venv/Scripts/python.exe",
            "cwd": "${workspaceFolder}/src/backend/api",
            "envFile": "${workspaceFolder}/src/backend/api/.env",
            "env": {
                "PYTHONUTF8": "1"
            }
        }
    ]
}